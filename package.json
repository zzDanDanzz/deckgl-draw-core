{
    "name": "@zzdandanzz/deckgl-draw",
    "private": false,
    "config": {
        "message": "chore: release v%s"
    },
    "version": "0.2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build:lib": "tsc -b && vite build -c vite.config.lib.ts",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "preversion": "npm run lint && npm run build:lib",
        "postversion": "git push origin main --tags && npm publish --access public"
    },
    "dependencies": {
        "immer": "^11.1.11"
    },
    "peerDependencies": {
        "@deck.gl/core": "^9.3.6",
        "@deck.gl/layers": "^9.3.6",
        "@deck.gl/react": "^9.3.6",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@deck.gl/core": "^9.3.6",
        "@deck.gl/layers": "^9.3.6",
        "@deck.gl/react": "^9.3.6",
        "@eslint/js": "^10.0.1",
        "@types/geojson": "^7946.0.16",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "maplibre-gl": "^5.24.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-map-gl": "^8.1.1",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.1",
        "vite-plugin-dts": "^5.0.3"
    }
}
